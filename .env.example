# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values before running the app.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── PROMPT OPTIONS ──────────────────────────────────────────────────────────
PROMPT_FILE = "main-prompts/main.json"


# ── AI API Keys ───────────────────────────────────────────────────────────────

# OpenRouter gives access to many models (GPT-4, Claude, Llama, etc.)
# Get a key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# DeepSeek models (optional — only needed if you want to use DeepSeek directly)
# Get a key at: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=


# ── Obsidian Integration (optional) ──────────────────────────────────────────

# API key for the Obsidian Local REST API plugin.
# Leave blank if you are not using Obsidian.
OBSIDIAN_API_KEY=

# URL for the Obsidian Local REST API plugin.
# IMPORTANT: When running via Docker, do NOT use http://127.0.0.1 or
# http://localhost — those point inside the container, not your machine.
# Use http://host.docker.internal instead (works on Mac, Windows, and Linux
# when using the provided docker-compose.yml).
OBSIDIAN_URL=http://host.docker.internal

# Tags used to pull lorebook entries from Obsidian notes.
# Change these only if you use different tags in your vault.
LOREBOOK_TAG="#lorebook"
LOREBOOK_ALWAYS_TAG="#lorebook-always"
LOREBOOK_NEVER_TAG="#lorebook-never"


# ── Database ──────────────────────────────────────────────────────────────────

# When running via Docker this is automatically set to an absolute path inside
# the container (see docker-compose.yml) so the value here is ignored.
# Only relevant if you run the app outside of Docker.
DATABASE_URL="file:./data/llm-nonsense.db"
