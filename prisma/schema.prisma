// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated"
}

generator json {
  provider = "prisma-json-types-generator"
}

datasource db {
  provider = "sqlite"
}

model Character {
  id         String   @id @default(cuid())
  name       String
  png        String
  pngHash    String
  Stories    Story[]
  createdAt  DateTime @default(now())
  modifiedAt DateTime @default(now()) @updatedAt
}

model Persona {
  id          String   @id @default(cuid())
  name        String
  image       String
  imageHash   String
  description String
  stories     Story[]
  createdAt   DateTime @default(now())
  modifiedAt  DateTime @default(now()) @updatedAt
}

model Story {
  id          String    @id @default(cuid())
  name        String
  characterId String
  character   Character @relation(fields: [characterId], references: [id])
  personaId   String
  persona     Persona   @relation(fields: [personaId], references: [id])
  worldId     String?
  world       World?    @relation(fields: [worldId], references: [id])
  lorebookId  String?
  lorebook    Lorebook? @relation(fields: [lorebookId], references: [id])
  chats       Chat[]
  promptId    String
  prompt      Prompt    @relation(fields: [promptId], references: [id])
  createdAt   DateTime  @default(now())
  modifiedAt  DateTime  @default(now()) @updatedAt
}

model Chat {
  id         String        @id @default(cuid())
  name       String
  storyId    String
  story      Story         @relation(fields: [storyId], references: [id])
  messages   ChatMessage[]
  /// [ChatFacts]
  facts      Json?
  createdAt  DateTime      @default(now())
  modifiedAt DateTime      @default(now()) @updatedAt
}

enum MessageRole {
  user
  system
  assistant
}

model ChatMessage {
  id         String           @id @default(cuid())
  chatId     String
  chat       Chat             @relation(fields: [chatId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  contents   MessageContent[]
  isHidden   Boolean          @default(false)
  createdAt  DateTime         @default(now())
  modifiedAt DateTime         @default(now()) @updatedAt
}

model MessageContent {
  id         String      @id @default(cuid())
  messageId  String
  message    ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  role       MessageRole
  isActive   Boolean     @default(false)
  /// [ChatMessageMetadata]
  metadata   Json?
  /// [ChatMessageParts]
  parts      Json
  createdAt  DateTime    @default(now())
  modifiedAt DateTime    @default(now()) @updatedAt
}

model World {
  id          String   @id @default(cuid())
  name        String
  description String
  image       String
  imageHash   String
  stories     Story[]
  createdAt   DateTime @default(now())
  modifiedAt  DateTime @default(now()) @updatedAt
}

model Lorebook {
  id         String   @id @default(cuid())
  name       String
  apiKey     String // Server is never available outside localhost, api key is a throw away
  port       Int
  stories    Story[]
  createdAt  DateTime @default(now())
  modifiedAt DateTime @default(now()) @updatedAt
}

model Prompt {
  id              String           @id @default(cuid())
  name            String
  maxTokens       Int              @default(80000)
  maxOutputTokens Int              @default(0)
  maxSteps        Int              @default(20)
  temperature     Float            @default(0.9)
  topK            Int              @default(64)
  topP            Float            @default(0.95)
  prefetch        Boolean          @default(false)
  promptFragments PromptFragment[]
  createdAt       DateTime         @default(now())
  modifiedAt      DateTime         @default(now()) @updatedAt
  stories         Story[]
}

enum PromptInjectTag {
  CHARACTER_DESCRIPTION
  CHARACTER_PERSONALITY
  CHARACTER_SCENARIO
  LAST_MESSAGE
  LOREBOOK_MEMORIES
  LOREBOOK_CONTEXT
  LOREBOOK_ENTRIES
  LOREBOOK_CONSTANT
  PERSONA_DESCRIPTION
  WORLD_DESCRIPTION
}

enum PromptFragmentType {
  CHAT_HISTORY
  CONTENT
  INJECT
}

model PromptFragment {
  id         String             @id @default(cuid())
  name       String
  type       PromptFragmentType
  role       MessageRole?
  enabled    Boolean            @default(true)
  content    String?
  injectTag  PromptInjectTag?
  order      Int
  prompt     Prompt?            @relation(fields: [promptId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  promptId   String?
  createdAt  DateTime           @default(now())
  modifiedAt DateTime           @default(now()) @updatedAt
}
