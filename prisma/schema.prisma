// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated"
}

generator json {
  provider = "prisma-json-types-generator"
}

datasource db {
  provider = "sqlite"
}

model Character {
  id         String   @id @default(cuid())
  name       String
  png        String
  pngHash    String
  Stories    Story[]
  createdAt  DateTime @default(now())
  modifiedAt DateTime @default(now()) @updatedAt
}

model Persona {
  id          String   @id @default(cuid())
  name        String
  image       String
  imageHash   String
  description String
  stories     Story[]
  createdAt   DateTime @default(now())
  modifiedAt  DateTime @default(now()) @updatedAt
}

model Story {
  id          String    @id @default(cuid())
  name        String
  characterId String
  character   Character @relation(fields: [characterId], references: [id])
  personaId   String
  persona     Persona   @relation(fields: [personaId], references: [id])
  worldId     String?
  world       World?    @relation(fields: [worldId], references: [id])
  lorebook    String?
  chats       Chat[]
  createdAt   DateTime  @default(now())
  modifiedAt  DateTime  @default(now()) @updatedAt
}

model Chat {
  id         String        @id @default(cuid())
  name       String
  storyId    String
  story      Story         @relation(fields: [storyId], references: [id])
  messages   ChatMessage[]
  createdAt  DateTime      @default(now())
  modifiedAt DateTime      @default(now()) @updatedAt
}

enum MessageRole {
  user
  system
  assistant
}

model ChatMessage {
  id         String      @id @default(cuid())
  chatId     String
  chat       Chat        @relation(fields: [chatId], references: [id])
  role       MessageRole
  /// [ChatMessageMeta]
  metadata   Json?
  /// [ChatMessageParts]
  parts      Json
  createdAt  DateTime    @default(now())
  modifiedAt DateTime    @default(now()) @updatedAt
}

model World {
  id          String   @id @default(cuid())
  name        String
  description String
  image       String
  imageHash   String
  stories     Story[]
  createdAt   DateTime @default(now())
  modifiedAt  DateTime @default(now()) @updatedAt
}

model Lorebook {
  id         String   @id @default(cuid())
  name       String
  apiKey     String
  createdAt  DateTime @default(now())
  modifiedAt DateTime @default(now()) @updatedAt
}
